@{
    ViewData["Title"] = "Едовичок | Каталог";
}

<main>
    <h1>Каталог блюд</h1>
    <div class="catalog-toolbar">
        <div>Добавить блюдо</div>
        <a class="recipe-card add-recipe-button" asp-controller="Home" asp-action="AddRecipe">Добавить</a>
    </div>
    <div class="layout">
        <aside class="filters">
            <p><strong>Фильтры</strong></p>
            <div id="filtersContainer">
                <p>Поиск:</p>
                <div class="search-wrapper">
                    <input type="text" id="searchInput" placeholder="Введите название блюда...">
                    <ul id="suggestionsList"></ul>
                </div>

                <p>Кухня:</p>
                <div id="categoriesContainer"></div>

                <p>Сложность:</p>
                <div id="difficultiesContainer"></div>

                <p>
                    <button id="resetBtn" type="button">Сбросить</button>
                    <button id="applyBtn" type="button">Применить</button>
                </p>
            </div>
        </aside>

        <section class="catalog">
            <div id="recipesCount" class="recipes-count"></div>
            <div id="cards" class="cards">
                <!-- Recipes will be loaded here via JavaScript -->
            </div>
            <div id="pagination" class="catalog-pagination"></div>
        </section>
    </div>
</main>

@section Scripts {
    <script src="~/js/catalog.js" asp-append-version="true"></script>
}

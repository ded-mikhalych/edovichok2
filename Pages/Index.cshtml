@page "/"
@model WebApplication.Pages.IndexModel
@{
    ViewData["Title"] = "Кулинариум";
}

<section class="hero">
    <div class="hero-copy">
        <p class="eyebrow">Спокойный гастрономический проект</p>
        <h1>Домашние рецепты и ресторанные обзоры без лишнего шума.</h1>
        <p class="hero-lead">
            На главной теперь только две линии: понятные рецепты для дома и отдельный слой с обзорами ресторанов.
            Без рейтингов, без избранного и без лишних обходных маршрутов.
        </p>
        <div class="hero-actions">
            <a class="button button-primary" asp-page="/Catalog">Открыть рецепты</a>
            <a class="button button-secondary" asp-page="/Restaurants">Смотреть рестораны</a>
        </div>
    </div>

    <aside class="hero-panel">
        <p class="panel-title">Срез проекта</p>
        <dl class="metrics-grid">
            <div>
                <dt>Рецептов</dt>
                <dd>@Model.RecipeCount</dd>
            </div>
            <div>
                <dt>Обзоров</dt>
                <dd>@Model.ArticleCount</dd>
            </div>
        </dl>
        <p class="panel-note">Главная больше не показывает категории кухонь и не отвлекает от двух основных сценариев.</p>
    </aside>
</section>

<section class="content-section">
    <div class="section-heading">
        <p class="eyebrow">Рестораны</p>
        <h2>Свежие обзоры мест, в которые действительно хочется зайти</h2>
    </div>
    <div class="editorial-grid">
        @foreach (var news in Model.Home.LatestNews)
        {
            <a class="editorial-card" asp-page="/Article" asp-route-id="@news.ArticleId">
                <img src="@news.ImageSrc" alt="@news.Title" />
                <div class="editorial-card-body">
                    <p class="card-kicker">Обзор</p>
                    <h3>@news.Title</h3>
                    <p>@news.Summary</p>
                </div>
            </a>
        }
    </div>
</section>

<section class="content-section">
    <div class="section-heading">
        <p class="eyebrow">Рецепты</p>
        <h2>Новая базовая подборка без служебных блоков и второстепенных сценариев</h2>
    </div>
    <div class="editorial-grid">
        @foreach (var recipe in Model.Home.NewestRecipes)
        {
            <a class="editorial-card" asp-page="@(recipe.ActionName == "Recipe" ? "/Recipe" : "/InDevelopment")" asp-route-slug="@recipe.Slug">
                <img src="@recipe.ImageSrc" alt="@recipe.Name" />
                <div class="editorial-card-body">
                    <p class="card-kicker">Рецепт</p>
                    <h3>@recipe.Name</h3>
                </div>
            </a>
        }
    </div>
</section>

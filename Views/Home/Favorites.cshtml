@model IEnumerable<WebApplication.Models.Recipe>
@{
    ViewData["Title"] = "Избранное";
}

<main>
    <h1>Избранные рецепты</h1>
    <p>В этом разделе собраны рецепты, которые наши пользователи отмечали как особенно удачные, простые в исполнении или незабываемые по вкусу. Избранное — это личная кулинарная коллекция, которая помогает быстро находить проверенные идеи для семейного ужина, праздника или вечернего десерта. Мы поощряем сохранять и делиться рецептами: вы можете добавлять свои находки и оставлять заметки о том, какие изменения проводили в процессе приготовления.</p>

    @if (!Model.Any())
    {
        <p>Пока нет избранных рецептов.</p>
    }
    else
    {
        <ul>
            @foreach (var recipe in Model)
            {
                <li>
                    @if (!string.IsNullOrWhiteSpace(recipe.Slug))
                    {
                        <a asp-controller="Home" asp-action="Recipe" asp-route-slug="@recipe.Slug">@recipe.Name</a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="InDevelopment">@recipe.Name</a>
                    }
                </li>
            }
        </ul>
    }

</main>
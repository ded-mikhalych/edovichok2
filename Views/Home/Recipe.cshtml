@model WebApplication.Models.RecipePageViewModel
@{
    ViewData["Title"] = $"Едовичок | {Model.Name}";
}

<main>
    <h1>@Model.Name</h1>

    <div class="recipe-page">
        <div class="left-col">
            <aside class="meta">
                <img src="@Model.MainImageSrc" alt="@Model.Name" />
                <div class="actions">
                    <button type="button">В избранное</button>
                    <button type="button">Оценить</button>
                    <p>Рейтинг: @Model.RatingText</p>
                </div>
            </aside>

            <div class="description">
                <h2>Описание блюда</h2>
                <p>@Model.Description</p>
                <p><b>Автор: </b>@Model.AuthorText</p>
                <p><b>Сложность: </b>@Model.DifficultyText</p>
                <p><b>Кухня: </b>@Model.CuisineText</p>

                <h2>Ингредиенты</h2>
                <div class="ingredients">
                    <ul>
                        @foreach (var ingredient in Model.Ingredients)
                        {
                            <li>@ingredient</li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="steps">
            <h2>Рецепт приготовления</h2>
            @foreach (var step in Model.Steps)
            {
                <div class="step">
                    <img src="@step.ImageSrc" alt="Шаг @step.StepNumber" />
                    <div class="step-content">
                        <h3>Шаг @step.StepNumber</h3>
                        <p>@step.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/recipe-page.js" asp-append-version="true"></script>
    <script src="~/js/step-modal.js" asp-append-version="true"></script>
    <script src="~/js/scale-ingredients.js" asp-append-version="true"></script>
}

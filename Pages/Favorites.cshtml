@page "/favorites"
@model WebApplication.Pages.FavoritesModel
@{
    ViewData["Title"] = "Избранное | Кулинариум";
}

<section class="page-heading">
    <p class="eyebrow">Избранное</p>
    <h1>Личная подборка рецептов, к которым хочется возвращаться.</h1>
    <p class="page-intro">Сейчас это редакционная выборка, но визуально и структурно раздел уже приведен к новой публичной витрине.</p>
</section>

<section class="list-card">
    @if (!Model.Recipes.Any())
    {
        <p>Пока здесь пусто.</p>
    }
    else
    {
        <ul class="link-list">
            @foreach (var recipe in Model.Recipes)
            {
                <li>
                    <a asp-page="@(recipe.ActionName == "Recipe" ? "/Recipe" : "/InDevelopment")" asp-route-slug="@recipe.Slug">
                        @recipe.Name
                    </a>
                </li>
            }
        </ul>
    }
</section>

@model WebApplication.Models.News
@{
    ViewData["Title"] = "Кулинарум | Подсластители под угрозой";
}

<main>
    <h1>@Model.Title</h1>

    <img src="~/images/@Model.ImageFileName" alt="@Model.Title" style="max-width:100%;height:auto;margin-bottom:16px;" />

    @if (!string.IsNullOrWhiteSpace(Model.ContentHtml))
    {
        @Html.Raw(Model.ContentHtml)
    }
    else
    {
        <p>@Model.Summary</p>
    }
</main>
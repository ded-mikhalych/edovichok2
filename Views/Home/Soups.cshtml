@model IEnumerable<WebApplication.Models.Recipe>
@{
    ViewData["Title"] = "Кулинарум | Супы";
}

<main>
    <h1>Супы</h1>
    <p>Супы — это основа многих кухонь мира: от наваристых мясных бульонов до лёгких овощных супов и кремов. Они согревают, насыщают и часто становятся центром семейного обеда. На этой странице мы собрали рецепты, советы по приготовлению и варианты адаптаций, которые помогут получить лучший результат независимо от уровня кулинарного опыта.</p>

    <p>При приготовлении супа важны два ключевых элемента: качественный бульон и правильная последовательность добавления ингредиентов. Мясные и костные бульоны требуют времени на медленную варку, чтобы отдать вкус и желирующие вещества; овощные супы выигрывают от использования сезонных овощей, а крем-супы — от последующего пробивания блендером и добавления сливок или растительных альтернатив для бархатистой текстуры.</p>

    @if (!Model.Any())
    {
        <p>Пока в базе нет рецептов супов.</p>
    }
    else
    {
        <ul>
            @foreach (var recipe in Model)
            {
                <li>
                    @if (!string.IsNullOrWhiteSpace(recipe.Slug))
                    {
                        <a asp-controller="Home" asp-action="Recipe" asp-route-slug="@recipe.Slug">@recipe.Name</a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="InDevelopment">@recipe.Name</a>
                    }
                </li>
            }
        </ul>
    }
</main>
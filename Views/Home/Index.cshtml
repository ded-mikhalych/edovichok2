@model WebApplication.Models.HomeViewModel
@{
    ViewData["Title"] = "Кулинарум | Кулинарный портал";
}

<h1>Кулинарный портал</h1>

<div>
    <h2>Кулинарные новости</h2>
    <div>
        @foreach (var news in Model.LatestNews)
        {
            var action = news.Title == "Подсластители под угрозой" ? "Article3" : "InDevelopment";
            <a class="news-card" asp-controller="Home" asp-action="@action">
                <img src="~/images/@news.ImageFileName" alt="@news.Title" />
                <h3>@news.Title</h3>
                <p>@news.Summary</p>
            </a>
        }
    </div>
</div>

<div>
    <h2>Новые рецепты</h2>
    <div class="cards">
        @foreach (var recipe in Model.NewestRecipes)
        {
            <a class="recipe-card"
               asp-controller="Home"
               asp-action="@(string.IsNullOrWhiteSpace(recipe.Slug) ? "Catalog" : "Recipe")"
               asp-route-slug="@recipe.Slug">
                <img src="~/images/@recipe.ImageFileName" alt="@recipe.Name" />
                <h4>@recipe.Name</h4>
            </a>
        }
    </div>
</div>

<div>
    <h2>Популярные категории</h2>
    <div class="cards">
        @foreach (var category in Model.PopularCategories)
        {
            var categoryAction = category.Name switch
            {
                "Russian" => "Soups",
                _ => "InDevelopment"
            };
            var categoryImage = category.Name switch
            {
                "Russian" => "soups.png",
                _ => "salads.png"
            };

            <a class="category-card" asp-controller="Home" asp-action="@categoryAction">
                <img src="~/images/@categoryImage" alt="@category.DisplayName" />
                <h4>@category.DisplayName</h4>
                <p style="font-size:13px;color:var(--muted);margin:4px 0 0;">@category.RecipeCount блюд</p>
            </a>
        }
    </div>
</div>

@page "/catalog"
@model WebApplication.Pages.CatalogModel
@{
    ViewData["Title"] = "Рецепты | Едовичок";
}

<section class="page-heading">
    <p class="eyebrow">Рецепты</p>
    <h1>Книга рецептов</h1>
    <p class="page-intro">
        Собранные домашние рецепты с простым поиском по названию, типу блюда и ингредиентам.
    </p>
</section>

<section class="catalog-shell">
    <aside class="catalog-sidebar">
        <div class="sidebar-card">
            <p class="card-kicker">Фильтры</p>
            <div id="filtersContainer">
                <label class="field-label">Тип блюда</label>
                <div id="categoriesContainer" class="filter-group"></div>

                <label class="field-label">Ингредиент</label>
                <div id="ingredientsContainer" class="filter-group"></div>

                <div class="filter-actions">
                    <button id="resetBtn" type="button" class="button button-secondary">Сбросить</button>
                    <button id="applyBtn" type="button" class="button button-primary">Применить</button>
                </div>
            </div>
        </div>
    </aside>

    <section class="catalog-stage">
        <div class="catalog-stage-header">
            <div>
                <p class="card-kicker">Рецепты</p>
            </div>
            <div id="recipesCount" class="recipes-count"></div>
        </div>

        <div class="catalog-search-bar">
            <label class="field-label" for="searchInput">Поиск по названию</label>
            <div class="search-wrapper">
                <input type="text" id="searchInput" placeholder="Введите название блюда..." />
                <ul id="suggestionsList"></ul>
            </div>
        </div>

        <div id="catalogSummary" class="catalog-summary">
            Каталог собирает результаты по текущему поиску и выбранным фильтрам.
        </div>

        <div id="cards" class="catalog-grid"></div>
        <div id="pagination" class="catalog-pagination"></div>
    </section>
</section>

<section id="viewHistorySection" class="catalog-history history-section" hidden>
    <div class="catalog-history-header">
        <div>
            <p class="card-kicker">История</p>
            <h3>Недавно просмотренные</h3>
        </div>
        <button id="clearHistoryBtn" type="button" class="button button-secondary">Очистить</button>
    </div>
    <div id="viewHistoryCards" class="catalog-history-grid"></div>
</section>

@section Scripts {
    <script src="~/js/catalog.js" asp-append-version="true"></script>
}

@model WebApplication.Models.ArticleViewModel
@{
    ViewData["Title"] = "Едовичок | " + Model.Title;
}

<main>
    <h1>@Model.Title</h1>

    <img src="@Model.ImageSrc" alt="@Model.Title" class="article-hero-img" />

    @if (!string.IsNullOrWhiteSpace(Model.ContentHtml))
    {
        @Html.Raw(Model.ContentHtml)
    }
    else
    {
        <p>@Model.Summary</p>
    }
</main>

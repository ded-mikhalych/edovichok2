@{
    ViewData["Title"] = "Едовичок | Соленые опята";
}

<main>
    <h1>Соленые опята</h1>

    <div class="recipe-page">
        <div class="left-col">
            <aside class="meta">
                <img src="~/images/mushrooms.png" alt="Соленые опята" />
                <div class="actions">
                    <button type="button">В Избранное</button>
                    <button type="button">Оценить</button>
                    <p>Рейтинг: 4.8</p>
                </div>
            </aside>

            <div class="description">
                <h2>Описание блюда</h2>
                <p>Ароматная хрустящая заготовка для вашего стола! Грибы остаются упругими и очень хрустящими. Отлично подходит к картошке, как закуска или дополнение к салатам.</p>
                <p><b>Сложность: </b>Средне</p>
                <p><b>Кухня: </b>Домашняя</p>

                <h2>Ингредиенты</h2>
                <div class="ingredients">
                    <ul>
                        <li>Опята (свежие) — 1.2 кг</li>
                        <li>Соль — 80 г (для засолки)</li>
                        <li>Перец горошком — 8–10 шт.</li>
                        <li>Лавровый лист — 3 шт.</li>
                        <li>Укроп (свежий) — 20 г</li>
                        <li>Листья смородины — 4–6 шт.</li>
                        <li>Хрен — 30 г (кусочек)</li>
                        <li>Чеснок — 6 зубчиков</li>
                        <li>Листья дуба — по вкусу (несколько)</li>
                        <li>Вода — 1 л (для рассола)</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="steps">
            <h2>Рецепт приготовления</h2>
            <div class="step"><img src="~/images/mushrooms/step1.jpg" alt="Шаг 1" /><div class="step-content"><h3>Шаг 1</h3><p>Подготовьте ингредиенты: промойте грибы, высушите и подготовьте специи.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step2.jpg" alt="Шаг 2" /><div class="step-content"><h3>Шаг 2</h3><p>Отрежьте корешки и тщательно промойте опята.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step3.jpg" alt="Шаг 3" /><div class="step-content"><h3>Шаг 3</h3><p>Варите грибы до готовности, затем достаньте и остудите.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step4.jpg" alt="Шаг 4" /><div class="step-content"><h3>Шаг 4</h3><p>Подготовьте маринад и доведите до кипения.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step5.jpg" alt="Шаг 5" /><div class="step-content"><h3>Шаг 5</h3><p>Добавьте грибы в маринад и варите 25 минут.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step6.jpg" alt="Шаг 6" /><div class="step-content"><h3>Шаг 6</h3><p>Подготовьте банки и крышки — простерилизуйте их.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step7.jpg" alt="Шаг 7" /><div class="step-content"><h3>Шаг 7</h3><p>Плотно разложите грибы по банкам и закатайте крышками.</p></div></div>
            <div class="step"><img src="~/images/mushrooms/step8.jpg" alt="Шаг 8" /><div class="step-content"><h3>Шаг 8</h3><p>Выдержите 4–6 недель для достижения насыщенного вкуса.</p></div></div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/recipe-page.js" asp-append-version="true"></script>
    <script src="~/js/step-modal.js" asp-append-version="true"></script>
    <script src="~/js/scale-ingredients.js" asp-append-version="true"></script>
}
